# ═══════════════════════════════════════════════
# BugAgent — environment variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════════════

# ── Telegram ──────────────────────────────────

TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# Comma-separated chat IDs to monitor (negative for groups, e.g. -1001234567890)
TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210

# ── Taiga ─────────────────────────────────────
TAIGA_URL=https://taiga.example.com
TAIGA_USERNAME=admin
TAIGA_PASSWORD=secret
TAIGA_PROJECT_SLUG=my-project

# Generic task-tracker selector (current adapter: taiga)
TASK_TRACKER_PROVIDER=taiga
# Optional generic project key/slug (if empty, TAIGA_PROJECT_SLUG is used)
TASK_TRACKER_PROJECT=

# ── LLM Provider ──────────────────────────────
# Options: ollama | vllm | llamacpp | openai | openrouter | anthropic
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# vLLM (OpenAI-compatible server)
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_API_KEY=
VLLM_MODEL=

# llama.cpp server (OpenAI-compatible mode)
LLAMACPP_BASE_URL=http://llamacpp:8080/v1
LLAMACPP_API_KEY=
LLAMACPP_MODEL=

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
# OpenRouter (used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-...
# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
# Model name for cloud providers
CLOUD_LLM_MODEL=gpt-4o-mini

# ── Qdrant ────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=telegram_bugs

# ── MCP endpoints (internal Docker network) ───
TELEGRAM_MCP_URL=http://telegram-mcp:3000
TAIGA_MCP_URL=http://taiga-mcp:8001

# ── Detection thresholds ──────────────────────
# Reranker score above which we pass to LLM
RERANK_SCORE_THRESHOLD=0.65
# LLM confidence above which a task is created
BUG_CLASSIFY_THRESHOLD=0.75

# ── Reranker runtime ──────────────────────────
# Operator/backend for reranking: qdrant | vllm | llamacpp | ollama | ann_only
RERANK_OPERATOR=qdrant
# Optional address of reranker operator (defaults to QDRANT_URL)
RERANK_BASE_URL=http://qdrant:6333
# Reranker model name used by selected operator
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# ── RabbitMQ ──────────────────────────────────
RABBITMQ_USER=bugagent
RABBITMQ_PASS=bugagent

# ── Service health via queue (webhook-like heartbeats) ─────────────
# Shared heartbeat routing key used by microservices
SERVICE_HEARTBEAT_ROUTING_KEY=service.health
# Heartbeat interval in seconds for publishers (agent / telegram-mcp / taiga-mcp)
SERVICE_HEARTBEAT_INTERVAL_SEC=30
# Enable heartbeat publishing in services
SERVICE_HEARTBEAT_ENABLED=true
# Enable health monitoring in agent
SERVICE_HEALTH_ENABLED=true
# Queue/key that agent listens to for heartbeats
SERVICE_HEALTH_QUEUE=service.health
# Warn if no heartbeat from a service for this long
SERVICE_HEALTH_STALE_SEC=90
# How often agent checks stale services
SERVICE_HEALTH_CHECK_INTERVAL_SEC=15

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
